# Copy to .env.test (gitignored) and fill before running e2e suite.
# Used by playwright.config.ts and e2e/fixtures.ts.

PLAYWRIGHT_BASE_URL=http://localhost:3000

# Primary test user (must exist in Supabase auth)
TEST_USER_A_EMAIL=
TEST_USER_A_PASSWORD=

# Secondary test user - required only for RLS isolation tests
TEST_USER_B_EMAIL=
TEST_USER_B_PASSWORD=

# Set to 1 when running against a real Supabase project (not demo mode).
# Skips persistence + RLS tests when unset to avoid false failures.
SUPABASE_CONFIGURED=

# Set to 1 to disable Playwright spawning `npm run dev` (e.g. when the
# server is already running externally).
PLAYWRIGHT_NO_SERVER=
